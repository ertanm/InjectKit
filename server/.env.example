# Database (Railway provides this when you add PostgreSQL)
DATABASE_URL=

# JWT Auth - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Comma-separated allowed origins. Required in production.
# Example: chrome-extension://YOUR_EXTENSION_ID
CORS_ORIGINS=

# Server
NODE_ENV=production
PORT=3000

# Dev only — never set to true in production
ALLOW_DEV_AUTO_AUTH=false

# Optional: Base URL for Stripe redirects when request origin is missing
# BASE_URL=https://yourdomain.com
